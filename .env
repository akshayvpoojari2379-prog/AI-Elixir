# Database Settings
POSTGRES_USER="DB-username"
POSTGRES_PASSWORD="DB-Password"
POSTGRES_DB="db-name"
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# Ollama / Local AI Settings
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
GEMINI_API_KEY="Gemini-api-key"
GEMINI_MODEL_NAME="Gemini-Version"


# Freshservice Settings
FRESHSERVICE_DOMAIN=asianpaints.freshservice.com
FRESHSERVICE_API_KEY="Freshservice-API-Key"

# Security --not required for dev
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Backend Config
ENVIRONMENT=development
API_V1_STR=/api/v1
PROJECT_NAME="AI Elixir"

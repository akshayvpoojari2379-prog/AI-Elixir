# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=*sleek#
POSTGRES_DB=ai_service_desk
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# Ollama / Local AI Settings
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=gemma:2b # or gemma:7b depending on what you downloaded
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Freshservice Settings
FRESHSERVICE_DOMAIN=your_domain.freshservice.com
FRESHSERVICE_API_KEY=your_freshservice_api_key

# Security
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Backend Config
ENVIRONMENT=development
API_V1_STR=/api/v1
PROJECT_NAME="AI Service Desk"
